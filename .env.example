# Required for AI features (seed, research, chat, itinerary generation).
# Set the key for whichever model providers you've selected below.
ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-proj-...

# Required for trip card photos (get a free key at pexels.com/api)
PEXELS_API_KEY=your_pexels_key_here

# Optional: Stadia Maps static-map base layer on the brochure's
# destination-area map. Without this, the destination map falls back to
# the illustrative paper render (state outlines + rivers + curated place
# labels). Free tier: 200K static-map requests/month for non-commercial
# use. Sign up at stadiamaps.com → create a Property → generate an API key.
# STADIA_API_KEY=

# ── Provider configuration (defaults shown; uncomment to override) ───────────
# Traverse talks to model and search providers through adapters. The defaults
# preserve the original Anthropic-only behavior.

# Model used for cheap/fast calls (seed, add, lock, planning chat).
# Supported providers: anthropic, openai
# TRAVERSE_MODEL_DEFAULT_PROVIDER=anthropic
# TRAVERSE_MODEL_DEFAULT=claude-sonnet-4-6
# Examples for OpenAI: TRAVERSE_MODEL_DEFAULT=gpt-4o-mini  /  gpt-4.1-mini

# Model used for research-heavy calls (deepen). Should be tool-use capable.
# TRAVERSE_MODEL_RESEARCH_PROVIDER=anthropic
# TRAVERSE_MODEL_RESEARCH=claude-opus-4-7
# Examples for OpenAI: TRAVERSE_MODEL_RESEARCH=gpt-4o  /  gpt-4.1

# Per-feature overrides (optional). Each feature inherits its slot above
# unless overridden here. Useful for routing cheap mechanical calls
# (lock, add) to a smaller/cheaper model than the default.
# TRAVERSE_MODEL_SEED_PROVIDER=
# TRAVERSE_MODEL_SEED=
# TRAVERSE_MODEL_ADD_PROVIDER=
# TRAVERSE_MODEL_ADD=
# TRAVERSE_MODEL_LOCK_PROVIDER=
# TRAVERSE_MODEL_LOCK=claude-haiku-4-5         # e.g. cheaper formatting model
# TRAVERSE_MODEL_CHAT_PROVIDER=
# TRAVERSE_MODEL_CHAT=
# TRAVERSE_MODEL_DEEPEN_PROVIDER=
# TRAVERSE_MODEL_DEEPEN=

# Search backend used by /deepen.
#   anthropic-builtin → Anthropic runs web_search server-side (only valid
#                       when TRAVERSE_MODEL_RESEARCH_PROVIDER=anthropic).
#   tavily            → client-side Tavily API; works with any model provider.
#                       Required when using non-Anthropic research models.
# TRAVERSE_SEARCH_PROVIDER=anthropic-builtin
# TAVILY_API_KEY=tvly-...

# Display name shown in UI ("Ask {name} about this trip", etc.).
# Defaults to "Field guide". Override to match whatever assistant you're using.
# TRAVERSE_ASSISTANT_NAME=Field guide

# Public read-only share links (optional). Set this to enable per-trip
# Share URLs in the UI. Tokens are HMAC-SHA256(slug, secret); rotating the
# secret invalidates all existing share links instantly. Generate with e.g.
# `openssl rand -base64 32`.
# TRAVERSE_SHARE_SECRET=
