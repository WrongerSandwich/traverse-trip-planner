# Build artifacts
node_modules
build
.svelte-kit

# Secrets (env file is provided at runtime via docker-compose env_file)
.env
.env.*

# Everything user-managed (trip stages, home.md, settings.json, .cache/) lives
# under data/ and is provided at runtime via the bind mount.
data

# Tooling, tests, docs — not needed in the runtime image
.claude
.git
.gitignore
.github
tests
docs
*.log
/tmp
.DS_Store

# This file itself
.dockerignore
