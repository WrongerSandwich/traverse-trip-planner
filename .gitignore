node_modules/
.svelte-kit/
build/
.DS_Store

# API keys — never commit
.env

# Personal trip data + runtime state — managed via the app, not committed.
# Everything user-managed (trip stages, home.md, settings.json, .cache/) lives
# under data/. The tracked `data/.gitkeep` ensures `git clone` materializes
# the directory as the cloning user — important for Docker, where dockerd
# would otherwise auto-create the bind-mount target as root and break writes
# from the container's non-root uid.
/data/*
!/data/.gitkeep

# Vite/dev logs
*.log
/tmp/

# Brainstorming companion sessions
.superpowers/

# Generated design-critique artifacts from the impeccable agent
.impeccable/

# Claude Code per-machine state: local permissions + agent worktrees
.claude/
