# ─── Traverse dev credentials ─────────────────────────────────────────────────
# Used by git worktrees created via `scripts/new-worktree.sh`.
#
# This is a TEMPLATE. The real file lives OUTSIDE any repo so it can never be
# committed — default path: ~/.config/traverse/dev.env (override with
# $TRAVERSE_DEV_ENV). new-worktree.sh symlinks it into each new worktree as
# `.env`, which feeds both `npm run dev` (Vite) and `npm run smoke` (dotenv).
#
# These are intentionally SEPARATE from the home-server production keys
# (.env / data/settings.json) so a runaway agent loop, a leaked transcript, or a
# throwaway worktree can't touch your production budget — and so you can rotate
# them without redeploying the container.
#
# Fill in the values you want. Placeholder values (your_*_here) and anything
# containing "..." are treated as UNSET by config.js, so any line you leave as-is
# is simply ignored — smoke and the app degrade gracefully per-provider.
# ──────────────────────────────────────────────────────────────────────────────

# ── Model provider keys ───────────────────────────────────────────────────────
# Fill the provider(s) you route to below. One OpenRouter key covers Claude,
# GPT, Gemini, Llama, etc.; or use the native Anthropic/OpenAI keys directly.
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Model routing ─────────────────────────────────────────────────────────────
# Defaults below mirror the home-server settings.json so worktree runs behave
# like production. Change provider/model to taste (e.g. point everything at
# anthropic if that's the only dev key you create).
TRAVERSE_MODEL_DEFAULT_PROVIDER=openrouter
TRAVERSE_MODEL_DEFAULT=google/gemini-3-flash-preview
TRAVERSE_MODEL_RESEARCH_PROVIDER=openrouter
TRAVERSE_MODEL_RESEARCH=openai/gpt-5-mini

# ── Search backend ────────────────────────────────────────────────────────────
# tavily works with any model provider (required for non-anthropic research
# models). Use anthropic-builtin ONLY if TRAVERSE_MODEL_RESEARCH_PROVIDER=anthropic.
TRAVERSE_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_key_here

# ── Service keys (optional; degrade gracefully) ───────────────────────────────
# Pexels → trip-card hero photos (falls back to a map thumbnail without it).
# Stadia → brochure destination base map (falls back to the paper render).
PEXELS_API_KEY=your_pexels_key_here
STADIA_API_KEY=your_stadia_key_here

# ── Optional display ──────────────────────────────────────────────────────────
# TRAVERSE_ASSISTANT_NAME=Field guide
