{
  "name": "traverse",
  "version": "0.1.0",
  "description": "A self-hosted road-trip filing cabinet: trips as markdown, LLM as assistant.",
  "author": "Evan Trout",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/WrongerSandwich/traverse-trip-planner#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/WrongerSandwich/traverse-trip-planner.git"
  },
  "bugs": {
    "url": "https://github.com/WrongerSandwich/traverse-trip-planner/issues"
  },
  "keywords": [
    "road-trip",
    "travel-planning",
    "self-hosted",
    "sveltekit",
    "llm",
    "anthropic",
    "openai",
    "markdown"
  ],
  "scripts": {
    "dev": "vite dev --port 3456",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke.js",
    "seed-sample": "node scripts/seed-sample.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-check --fail-on-warnings",
    "verify": "npm run check && npm test && npm run build"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.60.1",
    "svelte": "^5.55.8",
    "svelte-check": "^4.4.8",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "dotenv": "^17.4.2",
    "isomorphic-dompurify": "^3.14.0",
    "leaflet": "^1.9.4",
    "marked": "^18.0.4",
    "yaml": "^2.9.0"
  },
  "type": "module",
  "overrides": {
    "cookie": "^0.7.2"
  }
}
