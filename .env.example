# Required for AI features (seed, research, chat, itinerary generation).
# Set the key for whichever model providers you've selected below.
ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-proj-...
# OPENROUTER_API_KEY=sk-or-...    # one key for Claude, GPT, Gemini, Llama, and more — see DEPLOY.md#openrouter

# Recommended for trip card photos (get a free key at pexels.com/api).
# Without a real key, trip cards fall back to a map thumbnail and the home
# page shows a banner pointing you at Settings.
# PEXELS_API_KEY=

# Optional: Stadia Maps static-map base layer on the brochure's
# destination-area map. Without this, the destination map falls back to
# the illustrative paper render (state outlines + rivers + curated place
# labels). Free tier: 200K static-map requests/month for non-commercial
# use. Sign up at stadiamaps.com → create a Property → generate an API key.
# STADIA_API_KEY=

# ── Provider configuration (defaults shown; uncomment to override) ───────────
# Traverse talks to model and search providers through adapters. The defaults
# preserve the original Anthropic-only behavior.

# Model used for cheap/fast calls (seed, add, lock, planning chat).
# Supported providers: anthropic, openai, openrouter
# TRAVERSE_MODEL_DEFAULT_PROVIDER=anthropic
# TRAVERSE_MODEL_DEFAULT=claude-sonnet-4-6
# Examples for OpenAI: TRAVERSE_MODEL_DEFAULT=gpt-4o-mini  /  gpt-4.1-mini
# Examples for OpenRouter: TRAVERSE_MODEL_DEFAULT=anthropic/claude-3.5-sonnet  /  openai/gpt-4o-mini

# Model used for research-heavy calls (deepen). Should be tool-use capable.
# Supported providers: anthropic, openai, openrouter
# TRAVERSE_MODEL_RESEARCH_PROVIDER=anthropic
# TRAVERSE_MODEL_RESEARCH=claude-opus-4-7
# Examples for OpenAI: TRAVERSE_MODEL_RESEARCH=gpt-4o  /  gpt-4.1
# Examples for OpenRouter: TRAVERSE_MODEL_RESEARCH=anthropic/claude-opus-4-7  /  meta-llama/llama-3.1-70b-instruct
# Note: OpenRouter requires TRAVERSE_SEARCH_PROVIDER=tavily (anthropic-builtin is Anthropic-only).

# Per-feature overrides (optional). Each feature inherits its slot above
# unless overridden here. Useful for routing cheap mechanical calls
# (lock, add) to a smaller/cheaper model than the default.
# TRAVERSE_MODEL_SEED_PROVIDER=
# TRAVERSE_MODEL_SEED=
# TRAVERSE_MODEL_ADD_PROVIDER=
# TRAVERSE_MODEL_ADD=
# TRAVERSE_MODEL_LOCK_PROVIDER=
# TRAVERSE_MODEL_LOCK=claude-haiku-4-5         # e.g. cheaper formatting model
# TRAVERSE_MODEL_CHAT_PROVIDER=
# TRAVERSE_MODEL_CHAT=
# TRAVERSE_MODEL_RETRO_PROVIDER=
# TRAVERSE_MODEL_RETRO=
# TRAVERSE_MODEL_DEEPEN_PROVIDER=
# TRAVERSE_MODEL_DEEPEN=

# Search backend used by /deepen.
#   anthropic-builtin → Anthropic runs web_search server-side (only valid
#                       when TRAVERSE_MODEL_RESEARCH_PROVIDER=anthropic).
#   tavily            → client-side Tavily API; works with any model provider.
#                       Required when using non-Anthropic research models.
# TRAVERSE_SEARCH_PROVIDER=anthropic-builtin
# TAVILY_API_KEY=tvly-...

# Display name shown in UI ("Ask {name} about this trip", etc.).
# Defaults to "Field guide". Override to match whatever assistant you're using.
# TRAVERSE_ASSISTANT_NAME=Field guide

# Public read-only share links (optional). Set this to enable per-trip
# Share URLs in the UI. Tokens are HMAC-SHA256(slug, secret); rotating the
# secret invalidates all existing share links instantly. Generate with e.g.
# `openssl rand -base64 32`.
# TRAVERSE_SHARE_SECRET=

# Disable the /settings UI and POST /api/settings (both return 403). Recommended
# for production deployments reachable over untrusted networks where you prefer
# .env-only key management and don't want a browser-accessible key editor.
# TRAVERSE_DISABLE_SETTINGS_UI=true

# Config-write auth (loopback-by-default). POST /api/settings and PUT /api/home
# are gated to loopback callers. Set TRAVERSE_ALLOW_LAN_WRITES=1 if your
# browser runs on another device on the same trusted LAN; set TRUST_PROXY_FOR_AUTH=1
# behind a reverse proxy that unconditionally overwrites X-Forwarded-For
# (Caddy default; nginx needs proxy_set_header X-Forwarded-For $remote_addr).
# See DEPLOY.md → "Config-write auth (loopback-by-default)" and the threat
# model in src/lib/server/auth.js.
# TRAVERSE_ALLOW_LAN_WRITES=1
# TRUST_PROXY_FOR_AUTH=1

# ── Rate limits for AI-spending endpoints (optional overrides) ───────────────
# Token-bucket per endpoint, per client IP. Capacity is the max immediate
# burst; refill is the sustained rate in tokens/minute. Defaults are tuned for
# household use — uncomment to override. Trip-scoped endpoints (deepen, retro,
# receipts, chat) additionally key by slug so abuse of one trip doesn't drain
# the bucket for the others.
#
# Defaults:
#   seed             capacity=5   refill=0.5/min   (~30/hour burst-tolerant)
#   add              capacity=10  refill=1/min     (~60/hour)
#   deepen           capacity=3   refill=0.25/min  (~15/hour — research is the most expensive call)
#   deepen-section   capacity=5   refill=0.5/min
#   retro            capacity=5   refill=0.5/min
#   receipts         capacity=5   refill=0.3/min   (vision tokens are pricier)
#   chat             capacity=30  refill=6/min     (per slug)
#   brochure         capacity=3   refill=0.25/min
#
# TRAVERSE_RATELIMIT_SEED_CAPACITY=5
# TRAVERSE_RATELIMIT_SEED_REFILL_PER_MIN=0.5
# TRAVERSE_RATELIMIT_DEEPEN_CAPACITY=3
# TRAVERSE_RATELIMIT_DEEPEN_REFILL_PER_MIN=0.25
# TRAVERSE_RATELIMIT_DEEPEN_SECTION_CAPACITY=5
# TRAVERSE_RATELIMIT_DEEPEN_SECTION_REFILL_PER_MIN=0.5
# TRAVERSE_RATELIMIT_RECEIPTS_CAPACITY=5
# TRAVERSE_RATELIMIT_RECEIPTS_REFILL_PER_MIN=0.3
#
# Note: when running behind a reverse proxy, the proxy IP becomes the bucket
# key unless you've configured SvelteKit's address-handling for trusted proxies.
# The per-IP keying then effectively becomes one shared bucket — still useful
# as a global ceiling.
